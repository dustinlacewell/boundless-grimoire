---
const base = import.meta.env.BASE_URL;

const shots = [
  { src: "screenshots/overlay.png", alt: "Full overlay view with deck and search results", caption: "The overlay — deck, analytics, and search side-by-side." },
  { src: "screenshots/search.png", alt: "Filter bar and search results", caption: "Filter on color, type, rarity, set, and arbitrary Scryfall queries." },
  { src: "screenshots/analytics.png", alt: "Deck analytics charts", caption: "Mana curve, creature/non-creature split, color demand vs. supply." },
];
---

<section class="mx-auto max-w-6xl px-6 py-20">
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-3">See it in action</h2>
  <p class="text-center text-text-muted max-w-2xl mx-auto mb-12">
    Opens over the page you're on with one click. Doesn't navigate away.
  </p>

  <div class="grid gap-8">
    {shots.map((s) => (
      <figure class="rounded-xl border border-border bg-bg-1 overflow-hidden">
        <img
          src={`${base}${s.src}`}
          alt={s.alt}
          loading="lazy"
          class="w-full block"
        />
        <figcaption class="px-5 py-3 text-sm text-text-muted border-t border-border">
          {s.caption}
        </figcaption>
      </figure>
    ))}
  </div>
</section>
