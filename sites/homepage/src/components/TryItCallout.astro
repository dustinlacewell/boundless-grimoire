---
/**
 * "Click to try now" callout pinned to the top-left of the viewport,
 * with a curved arrow pointing at the trigger button.
 *
 * Layout:
 *   - Trigger button lives at top:0 / left:0, 98×52.
 *   - Label sits below-right of the trigger, rotated for personality.
 *   - SVG arrow curves from the label up-and-left, terminating BELOW
 *     the trigger's bottom edge (y > 52) so the arrowhead doesn't get
 *     covered by the button.
 *
 * Visibility: this element has no z-index. The overlay is fixed
 * inset-0 with z-index 2147483647, so when the user clicks the trigger
 * and the overlay opens, the callout disappears behind it.
 */
---

<div class="bg-try-it-callout pointer-events-none fixed top-0 left-0">
  <svg
    width="180"
    height="100"
    viewBox="0 0 180 100"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    style="color: var(--color-accent);"
  >
    <defs>
      <marker
        id="bg-try-arrow-head"
        viewBox="0 0 10 10"
        refX="2"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto"
      >
        <path d="M0,0 L10,5 L0,10 Z" fill="currentColor" />
      </marker>
    </defs>
    <!--
      Cubic curve from the label (right side) up-and-left, terminating
      BELOW the trigger button at (55, 68). Trigger occupies (0,0)→
      (98,52), so y=68 is 16px below it — clear of the button so the
      arrowhead is visible. The path's tangent at the endpoint points
      up-and-left, making the arrowhead appear to point at the button.
    -->
    <path
      d="M 138 92 C 110 96, 80 100, 55 68"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      marker-end="url(#bg-try-arrow-head)"
    />
  </svg>

  <!-- Label sits below-right of the trigger so the arrow has a clear
       run. Slight rotation gives it a hand-drawn feel. -->
  <div
    class="absolute font-bold text-[18px] tracking-tight leading-none whitespace-nowrap"
    style="top: 80px; left: 145px; color: var(--color-accent); transform: rotate(-6deg); transform-origin: top left;"
  >
    Click to try now
  </div>
</div>

<style>
  /* Hide on narrow viewports — the trigger is still discoverable, the
     callout just gets in the way at small sizes. */
  @media (max-width: 640px) {
    .bg-try-it-callout { display: none; }
  }
</style>
