{
  "manifest_version": 3,
  "name": "Boundless Grimoire",
  "version": "0.6.1",
  "description": "Local-first deckbuilder overlay for untap.in. Uses Scryfall for card data; decks live in chrome.storage.",
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["keyrune/*", "assets/*", "chunks/*"],
      "matches": ["https://untap.in/*", "https://*.untap.in/*"]
    }
  ],
  "action": {
    "default_title": "Boundless Grimoire"
  },
  "content_scripts": [
    {
      "matches": ["https://untap.in/*", "https://*.untap.in/*"],
      "js": ["untapBridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://untap.in/*", "https://*.untap.in/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
