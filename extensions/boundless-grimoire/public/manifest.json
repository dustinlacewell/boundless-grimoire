{
  "manifest_version": 3,
  "name": "Boundless Grimoire",
  "version": "0.7.2",
  "description": "Comfy and customizable deck builder for Magic: The Gathering that syncs with Untap.in",
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["keyrune/*", "assets/*", "chunks/*"],
      "matches": ["https://untap.in/*", "https://*.untap.in/*"]
    }
  ],
  "action": {
    "default_title": "Boundless Grimoire"
  },
  "content_scripts": [
    {
      "matches": ["https://untap.in/*", "https://*.untap.in/*"],
      "js": ["untapBridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://untap.in/*", "https://*.untap.in/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
